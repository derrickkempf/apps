{
  "manifest_version": 3,
  "name": "DEWD Timer",
  "version": "1.0",
  "description": "A 15-minute focus timer by DEWD.COOL",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["storage"]
}
